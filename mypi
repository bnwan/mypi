#!/usr/bin/env sh
IMAGE="mypi-dev"
CONFIG_DIR="$HOME/.mypi/agent"
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$(command -v "$0" || echo "$0")")")" && pwd)"

# Parse arguments
CONTAINER_NAME=""
WORKSPACE="$(pwd)"
BUILD=0
LIST=0
STOP=""
EXTRA_ARGS=""

while [ $# -gt 0 ]; do
  case "$1" in
    --build)
      BUILD=1
      shift
      ;;
    --name)
      CONTAINER_NAME="$2"
      shift 2
      ;;
    --name=*)
      CONTAINER_NAME="${1#*=}"
      shift
      ;;
    --workspace)
      WORKSPACE="$2"
      shift 2
      ;;
    --workspace=*)
      WORKSPACE="${1#*=}"
      shift
      ;;
    --list)
      LIST=1
      shift
      ;;
    --stop)
      STOP="$2"
      shift 2
      ;;
    --stop=*)
      STOP="${1#*=}"
      shift
      ;;
    --help|-h)
      echo "Usage: mypi [options] [pi-args...]"
      echo ""
      echo "Options:"
      echo "  --build              Rebuild the Docker image"
      echo "  --name NAME          Start a named instance (allows multiple instances)"
      echo "  --workspace PATH     Mount a different workspace directory (default: current directory)"
      echo "  --list               List running mypi containers"
      echo "  --stop NAME          Stop a named mypi container"
      echo "  --help, -h           Show this help"
      echo ""
      echo "All other arguments are passed to pi"
      exit 0
      ;;
    --)
      shift
      EXTRA_ARGS="$*"
      break
      ;;
    *)
      EXTRA_ARGS="$*"
      break
      ;;
  esac
done

# Handle --list
if [ "$LIST" -eq 1 ]; then
  echo "Running mypi containers:"
  docker ps --filter "ancestor=$IMAGE" --format "table {{.Names}}\t{{.Status}}\t{{.Mounts}}" 2>/dev/null | grep -v "^NAMES" || echo "No running instances found"
  exit 0
fi

# Handle --stop
if [ -n "$STOP" ]; then
  echo "Stopping mypi container: $STOP"
  docker stop "$STOP" 2>/dev/null && docker rm "$STOP" 2>/dev/null
  if [ $? -eq 0 ]; then
    echo "Stopped and removed $STOP"
  else
    echo "Failed to stop $STOP (container may not exist)"
    exit 1
  fi
  exit 0
fi

if [ "$BUILD" -eq 1 ] || ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
  docker build -t "$IMAGE" "$SCRIPT_DIR"
fi

mkdir -p "$CONFIG_DIR"

# Resolve GH_TOKEN: prefer explicit GH_TOKEN, fall back to GITHUB_TOKEN, then try gh CLI on the host
if [ -z "$GH_TOKEN" ] && [ -n "$GITHUB_TOKEN" ]; then
  GH_TOKEN="$GITHUB_TOKEN"
fi
if [ -z "$GH_TOKEN" ] && command -v gh >/dev/null 2>&1; then
  GH_TOKEN="$(gh auth token 2>/dev/null || true)"
fi

# Build docker run command
DOCKER_ARGS="-it"

if [ -n "$CONTAINER_NAME" ]; then
  DOCKER_ARGS="$DOCKER_ARGS --name \"$CONTAINER_NAME\""
else
  DOCKER_ARGS="$DOCKER_ARGS --rm"
fi

eval exec docker run $DOCKER_ARGS \
  -v "$CONFIG_DIR:/root/.mypi/agent" \
  -v "$WORKSPACE:/workspace" \
  ${ANTHROPIC_API_KEY:+-e ANTHROPIC_API_KEY="$ANTHROPIC_API_KEY"} \
  ${OPENAI_API_KEY:+-e OPENAI_API_KEY="$OPENAI_API_KEY"} \
  ${GOOGLE_API_KEY:+-e GOOGLE_API_KEY="$GOOGLE_API_KEY"} \
  ${GH_TOKEN:+-e GH_TOKEN="$GH_TOKEN"} \
  ${GH_TOKEN:+-e GITHUB_TOKEN="$GH_TOKEN"} \
  "$IMAGE" $EXTRA_ARGS
