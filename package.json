{
  "name": "mypi",
  "version": "0.1.0",
  "description": "CLI tool for running pi coding agent in Docker containers",
  "main": "src/main.ts",
  "bin": {
    "mypi": "bin/mypi"
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "dev": "bun run src/main.ts",
